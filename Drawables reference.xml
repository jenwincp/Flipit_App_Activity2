<!--
  DRAWABLES — create each section as its own file in res/drawable/
  ================================================================
-->


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_coin_glow.xml
     Outer glow ring around coin
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@color/gold_glow" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_coin_outer.xml
     Gold outer ring of coin
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@color/gold_dark" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_coin_heads.xml
     Gold coin face (Heads)
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="80dp"
        android:startColor="@color/gold_light"
        android:endColor="@color/gold_primary" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_coin_tails.xml
     Silver coin face (Tails)
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="80dp"
        android:startColor="@color/silver_light"
        android:endColor="@color/silver_primary" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_coin_glow_silver.xml
     Silver glow (shown for Tails result)
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@color/silver_glow" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_coin_outer_silver.xml
     Silver outer ring (Tails)
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@color/silver_dark" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_flip_button.xml
     Gold flip button with press state
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_pressed" />
            <corners android:radius="@dimen/btn_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/gold_primary" />
            <corners android:radius="@dimen/btn_radius" />
        </shape>
    </item>
</selector>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_clear_button.xml
     Subtle outline Clear button
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#00000000" />
    <stroke android:width="1dp" android:color="@color/divider" />
    <corners android:radius="8dp" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_stat_bar_track.xml
     Grey background track for stat bars
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/bg_surface" />
    <corners android:radius="@dimen/stat_bar_radius" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_stat_bar_heads.xml
     Gold fill bar for Heads
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/stat_heads" />
    <corners android:radius="@dimen/stat_bar_radius" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_stat_bar_tails.xml
     Silver-grey fill bar for Tails
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/stat_tails" />
    <corners android:radius="@dimen/stat_bar_radius" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_history_badge_heads.xml
     Gold circular badge for Heads history items
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@color/history_heads_bg" />
    <stroke android:width="1.5dp" android:color="@color/gold_dark" />
</shape>


<!-- ═══════════════════════════════════════════
     FILE: res/drawable/bg_history_badge_tails.xml
     Silver circular badge for Tails history items
═══════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@color/history_tails_bg" />
    <stroke android:width="1.5dp" android:color="@color/silver_dark" />
</shape>
